{
  "enabled": true,
  "network": {
    "allowedDomains": [
      "github.com",
      "*.github.com",
      "raw.githubusercontent.com",
      "objects.githubusercontent.com",
      "npmjs.org",
      "*.npmjs.org",
      "registry.yarnpkg.com",
      "crates.io",
      "*.crates.io",
      "rust-lang.org",
      "*.rust-lang.org",
      "rustup.rs",
      "*.rustup.rs",
      "hackage.haskell.org",
      "haskell.org",
      "*.haskell.org",
      "stackage.org",
      "*.stackage.org",
      "hub.docker.com"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": ["/Users", "/home"],
    "allowRead": [
      ".",
      "~/AGENTS.md",
      "~/.gitconfig",
      "~/.pi",
      "~/.config",
      "~/.local",
      "~/Library",
      "~/Developer",
      "~/.cargo",
      "~/.rustup",
      "~/.cabal",
      "~/.stack",
      "~/.ghcup",
      "~/.npm",
      "~/dotfiles",
      "/opt/homebrew/Cellar"
    ],
    "allowWrite": [
      ".",
      "/tmp",
      "/private/tmp",
      "~/.cargo",
      "~/.rustup",
      "~/.cabal",
      "~/.stack",
      "~/.ghcup",
      "~/.npm"
    ],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key"]
  }
}
